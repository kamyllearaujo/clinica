<script>
let historicoPaginas = []; 

// Dados Temporários coletados durante as etapas
let agendamentoTemporario = {};

// Array Principal de Consultas
let bancoAgendamentos = [
    {
        id: 1,
        clinica: "Clínica Suspeita",
        especialidade: "Urologista",
        medico: "DR RAPOSO",
        paciente: "Ze da manga",
        data: "2026-06-15T14:00"
    }
];

function renderizarAgendamentos() {
    const listaPaciente = document.getElementById("lista_agendamentos_paciente");
    const listaClinica = document.getElementById("lista_agendamentos_clinica");
    const selectCancelar = document.getElementById("sel_cancelar_consulta");
    
    listaPaciente.innerHTML = "";
    listaClinica.innerHTML = "";
    selectCancelar.innerHTML = '<option value="">Selecione uma consulta...</option>';
    
    bancoAgendamentos.forEach(agendamento => {
        // Perfil do Paciente
        listaPaciente.innerHTML += `
            <div class="item" style="border-radius: 10px; padding: 10px;">
                🟢 <strong>${agendamento.clinica.toUpperCase()}</strong><br>
                <strong>ÁREA:</strong> <span style="border: 1px solid #14853f; padding: 2px 8px; border-radius: 10px; font-size: 11px;">${agendamento.especialidade.toUpperCase()}</span><br>
                <span style="display:block; margin-top:5px;"><strong>MÉDICO:</strong> <span style="border: 1px solid #14853f; padding: 2px 8px; border-radius: 10px; font-size: 11px;">${agendamento.medico}</span></span>
            </div>
        `;
        
        // Perfil da Clínica Suspeita
        if(agendamento.clinica === "Clínica Suspeita") {
            listaClinica.innerHTML += `
                <div class="item">
                    <strong>Paciente:</strong> ${agendamento.paciente}<br>
                    <strong>Médico:</strong> ${agendamento.medico}<br>
                    <strong>Especialidade:</strong> ${agendamento.especialidade}
                </div>
            `;
        }

        // Dropdown da tela de cancelamento
        selectCancelar.innerHTML += `
            <option value="${agendamento.id}">${agendamento.paciente} - ${agendamento.medico} (${agendamento.especialidade})</option>
        `;
    });
}

function irParaPagamento(event) {
    event.preventDefault();
    agendamentoTemporario = {
        clinica: document.getElementById("sel_clinica").value,
        especialidade: document.getElementById("sel_especialidade").value,
        data: document.getElementById("sel_data").value
    };
    abrirPagina('pagamento_tela');
}

function salvarAgendamentoCompleto(event) {
    event.preventDefault();
    
    let medicoDefinido = "DR RAPOSO";
    if(agendamentoTemporario.especialidade === "Clínico Geral") medicoDefinido = "DRA MARINA";
    if(agendamentoTemporario.especialidade === "Cardiologista") medicoDefinido = "DR SILVA";

    bancoAgendamentos.push({
        id: Date.now(),
        clinica: agendamentoTemporario.clinica,
        especialidade: agendamentoTemporario.especialidade,
        data: agendamentoTemporario.data,
        medico: medicoDefinido,
        paciente: "Ze da manga",
        formaPagamento: document.getElementById("sel_forma_pagamento").value,
        planoSaude: document.getElementById("sel_plano_saude").value
    });
    
    renderizarAgendamentos();
    alert('Consulta agendada com sucesso! 🎉');
    
    // Reseta Formulários
    document.getElementById("sel_clinica").value = "";
    document.getElementById("sel_especialidade").value = "";
    document.getElementById("sel_data").value = "";
    document.getElementById("sel_forma_pagamento").value = "";
    document.getElementById("sel_plano_saude").value = "";
    
    abrirPagina('perfil_paciente');
}

function cancelarAtendimentoNoSistema(event) {
    event.preventDefault();
    const idParaDeletar = Number(document.getElementById("sel_cancelar_consulta").value);
    if(!idParaDeletar) return;

    bancoAgendamentos = bancoAgendamentos.filter(agend -> agend.id !== idParaDeletar);
    renderizarAgendamentos();
    
    alert('Atendimento cancelado com sucesso! ❌');
    abrirPagina('mais_opcoes');
}

function abrirPagina(id){
    let paginaAtual = document.querySelector(".pagina.ativa");
    if(paginaAtual && paginaAtual.id !== id) {
        historicoPaginas.push(paginaAtual.id); 
    }
    let paginas = document.querySelectorAll(".pagina");
    paginas.forEach(function(pagina){
        pagina.classList.remove("ativa");
    });
    document.getElementById(id).classList.add("ativa");
    window.scrollTo(0, 0);
}

function voltarPagina() {
    if(historicoPaginas.length > 0) {
        let paginaAnterior = historicoPaginas.pop(); 
        let paginas = document.querySelectorAll(".pagina");
        paginas.forEach(function(pagina){
            pagina.classList.remove("ativa");
        });
        document.getElementById(paginaAnterior).classList.add("ativa");
        window.scrollTo(0, 0);
    } else {
        abrirPagina('home');
    }
}

// Inicialização
renderizarAgendamentos();
</script>
 
