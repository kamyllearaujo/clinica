<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VitaVida</title>
 
<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}
 
body{
    background:#efefef;
}
 
/* TOPO */
header{
    width:100%;
    background:white;
    padding:20px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom:5px solid #b7ec58;
    position:sticky;
    top:0;
    z-index: 1000;
}
 
.logo{
    color:#52a30d;
    font-size:32px;
    font-weight:bold;
}
 
nav{
    display:flex;
    gap:20px;
}
 
nav button{
    background:none;
    border:none;
    color:#1f7a1f;
    font-weight:bold;
    cursor:pointer;
    font-size:16px;
}
 
/* PÁGINAS */
.pagina{
    display:none;
}
 
.ativa{
    display:block;
}
 
/* CONTAINER */
.container{
    width:100%;
    min-height:calc(100vh - 83px);
    display:flex;
    justify-content:center;
    align-items:center;
    padding:40px;
}
 
/* CARD */
.card{
    background:white;
    width:420px;
    border-radius:20px;
    padding:35px;
    box-shadow:0 0 20px rgba(0,0,0,0.1);
    border-bottom:15px solid #b7ec58;
    position: relative;
}
 
.card h1{
    color:#52a30d;
    margin-bottom:5px;
}
 
.card h2{
    color:#14853f;
    margin-bottom:25px;
    font-size:28px;
    display: flex;
    align-items: center;
    gap: 8px;
}
 
.card p{
    color:#14853f;
    margin-bottom:10px;
    font-size:14px;
}
 
label{
    color:#14853f;
    font-weight:bold;
    font-size:14px;
    display: block;
    margin-top: 10px;
}
 
/* INPUTS */
input, select{
    width:100%;
    padding:12px;
    margin-top:5px;
    margin-bottom:15px;
    border:2px solid #222;
    border-radius:30px;
    outline:none;
    background: white;
}
 
/* BOTÕES */
button, .btn-link{
    width:100%;
    background:#52a30d;
    color:white;
    border:none;
    padding:14px;
    border-radius:30px;
    cursor:pointer;
    font-size:16px;
    font-weight:bold;
    transition:0.3s;
    text-align: center;
    display: block;
    text-decoration: none;
    margin-bottom: 10px;
}
 
button:hover, .btn-link:hover{
    background:#3f8108;
}
 
.btn-outline {
    background: white;
    color: #14853f;
    border: 2px solid #14853f;
}
.btn-outline:hover {
    background: #14853f;
    color: white;
}

.btn-floating {
    background: #52a30d;
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 20px auto 0 auto;
    cursor: pointer;
    border: none;
}
 
/* LINKS */
.links{
    margin-top:20px;
    display:flex;
    justify-content:space-between;
}
 
.links a{
    text-decoration:none;
    color:#14853f;
    font-size:14px;
    cursor:pointer;
}
 
/* PERFIL E LISTAS */
.perfil{
    text-align:center;
}
 
.foto{
    width:90px;
    height:90px;
    border-radius:50%;
    background:#ddd;
    margin:20px auto;
    background-size: cover;
    background-position: center;
}
 
.header-perfil {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #14853f;
}
 
.icones-acoes {
    display: flex;
    gap: 10px;
    cursor: pointer;
    font-size: 20px;
}
 
.agendamentos, .medicos-lista{
    margin-top:25px;
    text-align: left;
}
 
.item{
    border:2px solid #14853f;
    border-radius:20px;
    padding:15px;
    margin-bottom:12px;
    color:#14853f;
    font-size: 13px;
}
 
/* HOME E SELEÇÃO */
.home{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
}

.home h2 {
    justify-content: center;
}
 
.opcoes-verticais {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-top: 20px;
    width: 100%;
}
 
.opcao-selecao {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
    color: #14853f;
    cursor: pointer;
    padding: 15px;
    border: 2px solid #b7ec58;
    border-radius: 15px;
    transition: 0.2s;
}
.opcao-selecao:hover {
    background: #f0fdf4;
    border-color: #52a30d;
}

.opcao-selecao .nome-clinica {
    font-weight: bold;
    font-size: 16px;
}

.opcao-selecao .info-clinica {
    font-size: 12px;
    color: #666;
}

/* CHAT STYLES */
.chat-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 15px;
    margin-bottom: 20px;
}
.balao-chat {
    display: flex;
    align-items: center;
    gap: 10px;
}
.balao-chat.robo {
    justify-content: flex-start;
}
.balao-chat.usuario {
    justify-content: flex-end;
}
.texto-balao {
    padding: 10px 15px;
    border: 2px solid #14853f;
    border-radius: 20px;
    font-size: 13px;
    color: #14853f;
    max-width: 80%;
}
.balao-chat.usuario .texto-balao {
    background-color: #f0fdf4;
}
 
/* RESPONSIVO */
@media(max-width:500px){
    .card{
        width:100%;
    }
    header{
        flex-direction:column;
        gap:20px;
    }
}
</style>
</head>
